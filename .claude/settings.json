{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-source-modification.sh Edit \"$TOOL_INPUT_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-commit-protected-branch.sh Bash \"$TOOL_INPUT_COMMAND\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-memory-update.sh \"$TOOL_NAME\" \"$TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
