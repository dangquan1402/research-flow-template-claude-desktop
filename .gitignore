.env
.env.*
__pycache__/
*.pyc
.DS_Store
.vscode/
.idea/
node_modules/

# uv / venv
.venv/

# MLflow experiment tracking
mlruns/
mlartifacts/
mlflow.db

# Heavy / per-run experiment artifacts (regenerate from configs)
experiments/checkpoints/
experiments/results/*.partial.json

# Example runtime outputs (regenerated by running the example; reference
# artifacts live in examples/single-gpu-experiment/{expected,sample-run}/)
examples/single-gpu-experiment/data/
examples/single-gpu-experiment/logs/
examples/single-gpu-experiment/results/

# Vast.ai state (per-machine, contains instance IDs and connection info)
experiments/.vastai-instance.json
experiments/.vastai-history.jsonl

# Rendered PDF pages from /read-pdf skill (regenerate from sources/*.pdf)
sources/_pdf-images/

# Claude Code per-machine state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Browser tooling
.playwright-mcp/

# Lint / build caches
.ruff_cache/

# Jekyll
_site/
.jekyll-cache/
.jekyll-metadata
.bundle/
Gemfile.lock

# Built docs (regenerate via scripts/build-docs-pdf.py + headless Chrome)
docs-pdf/
